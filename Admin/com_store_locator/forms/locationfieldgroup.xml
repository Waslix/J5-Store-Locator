<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Storelocator\Component\Store_locator\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="state" default="1" type="list" label=" " description=" " class="form-select-color-state" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="ordering"/>
        <field
                name="usergroup"
                type="UserGroupList"
                label="Access Control"
                description=" "
                layout="joomla.form.field.list-fancy-select"
                checksuperusergroup="0"
                default=""
                multiple="0"
                >
                <option value="0">Select User Group</option>
        </field> 
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_CREATED_BY"/>
    <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL" description="JGLOBAL_FIELD_MODIFIED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_MODIFIED_BY"/>
    <field name="title" filter="safehtml" type="text" required="true" label="Field Group Title" description=" " hint="Field Group Title"/>
    <field name="description" filter="JComponentHelper::filterText" type="textarea" required="false" label=" " description="enter a description for this group" buttons="true" />
  </fieldset>
</form>
