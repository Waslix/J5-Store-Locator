<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Storelocator\Component\Store_locator\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="state" default="1" type="list" label=" " description=" " class="form-select-color-state" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="ordering"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_CREATED_BY"/>
    <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL" description="JGLOBAL_FIELD_MODIFIED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_MODIFIED_BY"/>
    <field name="theme_title" filter="safehtml" type="text" required="true" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_THEME_TITLE" description=" " hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_THEME_TITLE"/>
    <field name="description" filter="safehtml" type="textarea" required="false" label=" " description=" " hint="enter a reminder to yourself about this map theme"/>
    <field name="toolbar_bg" type="color" default="#eee" format="hex" label="Toolbar Background" description=" " required="true" />
    <field name="results_bg" type="color" default="#eee" format="hex" label="Results Background" description=" " class="colorpicker" required="true" />
    <field name="button_color" type="color" default="#eee" format="hex" label="Button Color" description=" " class="colorpicker" required="true" />
    <field name="link_color" type="color" default="#eee" format="hex" label="Link Color" description=" " class="colorpicker" required="true" />
    <field name="theme_icon" directory="" type="media" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_THEME_ICON" description=" " hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_THEME_ICON"/>
  </fieldset>
</form>
