<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Storelocator\Component\Store_locator\Administrator\Field">
  <fieldset name="LocationData">
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="state" default="1" type="list" label=" " description=" " class="form-select-color-state" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="ordering"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_CREATED_BY"/>
    <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL" description="JGLOBAL_FIELD_MODIFIED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_MODIFIED_BY"/>
    <field name="locationlistingtitle" filter="safehtml" type="text" required="true" label="Location Title" description=" " hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_LOCATIONLISTINGTITLE"/>
<field 
  name="catid" 
  type="category"
  extension="com_store_locator"
  class="inputbox"
  default=""
  label=" "
  required="false"
  multiple="true"
  description="associate this location to one or more categories"
>
  <option value="0">JOPTION_SELECT_CATEGORY</option>
</field>
    <field name="user" type="user" label=" " description="link this location to a User Profile so the user can edit the location details through the frontend" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_USER"/>
    <field name="email" validate="email" type="email" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_EMAIL" description="COM_STORE_LOCATOR_FORM_DESC_LOCATORLOCATION_EMAIL" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_EMAIL"/>
    <field name="website" filter="safehtml" type="text" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_WEBSITE" description="COM_STORE_LOCATOR_FORM_DESC_LOCATORLOCATION_WEBSITE" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_WEBSITE"/>
    <field name="phone" filter="safehtml" type="tel" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_PHONE" description="COM_STORE_LOCATOR_FORM_DESC_LOCATORLOCATION_PHONE" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_PHONE"/>
    <field name="image" directory="" type="media" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_IMAGE" description="COM_STORE_LOCATOR_FORM_DESC_LOCATORLOCATION_IMAGE" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_IMAGE"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
  <fieldset name="LocationAddress">
    <field 
      name="street"
      type="text"
      label="COM_STORE_LOCATOR_STREET"
      description=" "
      hint="COM_STORE_LOCATOR_STREET"
      filter="string"
      required="false"
    />
    <field 
      name="city"
      type="text"
      label="COM_STORE_LOCATOR_CITY"
      description=" "
      hint="COM_STORE_LOCATOR_CITY"
      filter="string"
      required="false"
    />
    <field 
      name="user_state"
      type="text"
      label="COM_STORE_LOCATOR_STATE"
      description=" "
      hint="COM_STORE_LOCATOR_STATE"
      filter="string"
      required="false"
    />
    <field 
      name="zip_code"
      type="text"
      label="COM_STORE_LOCATOR_ZIP"
      description=" "
      hint="COM_STORE_LOCATOR_ZIP"
      filter="string"
      required="false"
    />
    <field name="latitude" type="text" label="Latitude"/>
    <field name="longitude" type="text" label="Longitude"/>
   <field name="country" 
       type="country" 
       value_field="country_name" 
       default="" 
       label="Select country" 
       description=" " />
   </fieldset>
   <fieldset name="options">
      <field name="frontend_screen" type="list" label="Frontend Screen">
          <option value="1">Mile</option>
          <option value="2">Kilometer</option>
      </field>
      
      <field multiple="true" class="inputbox mpt" name="map" type="sql" default="10" label=" " description="select the maps you want this location to appear on" query="SELECT id, maptitle FROM #__store_locator_maps" key_field="id" value_field="maptitle" />
      <field name="result_template" type="sql" default="10" label="Results" query="SELECT id, template_title FROM #__store_locator_location_results" key_field="id" value_field="template_title">
        <option value="0">Select results template</option>
      </field>
      <field name="card_template" type="sql" default="10" label="Card" query="SELECT id, template_title FROM #__store_locator_card_template" key_field="id" value_field="template_title">
        <option value="">Select card template</option>
      </field>
      <field name="details_tempate" type="sql" default="10" label="Details" query="SELECT id, template_title FROM #__store_locator_location_details" key_field="id" value_field="template_title">
        <option value="">Select details template</option>
      </field>
      <field name="admin_entry" type="sql" default="10" label="Admin" query="SELECT id, template_title FROM #__store_locator_admin_location_entries" key_field="id" value_field="template_title">
        <option value="">Default Template</option>
      </field>
    </fieldset>
</form>
