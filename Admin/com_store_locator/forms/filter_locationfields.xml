<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" description="COM_STORE_LOCATOR_SEARCH_FILTER_SUBMIT"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

        <field name="state"
               type="status"
               label="COM_STORE_LOCATOR_FILTER_STATE"
               description="COM_STORE_LOCATOR_FILTER_STATE_DESC"
               onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        

    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_STORE_LOCATOR_LIST_FULL_ORDERING"
               description="COM_STORE_LOCATOR_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">COM_STORE_LOCATOR_ID_ASC</option><option value="a.id DESC">COM_STORE_LOCATOR_ID_DESC</option><option value="a.state ASC">COM_STORE_LOCATOR_STATE_ASC</option>
			<option value="a.state DESC">COM_STORE_LOCATOR_STATE_DESC</option><option value="a.ordering ASC">COM_STORE_LOCATOR_ORDERING_ASC</option>
			<option value="a.ordering DESC">COM_STORE_LOCATOR_ORDERING_DESC</option><option value="a.locationlistingtitle ASC">COM_STORE_LOCATOR_LOCATIONLISTINGTITLE_ASC</option>
			<option value="a.locationlistingtitle DESC">COM_STORE_LOCATOR_LOCATIONLISTINGTITLE_DESC</option><option value="a.user ASC">COM_STORE_LOCATOR_USER_ASC</option>
			<option value="a.user DESC">COM_STORE_LOCATOR_USER_DESC</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_STORE_LOCATOR_LIST_LIMIT"
               description="COM_STORE_LOCATOR_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>

</form>