<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Storelocator\Component\Store_locator\Administrator\Field">
  <fieldset name="accesscontrol">
	
		<field name="asset_id" type="hidden" filter="unset" /> 
	
		<field
			name="rules"
			type="rules"
			label="JFIELD_RULES_LABEL"
			translate_label="false"
			filter="rules"
			validate="rules"
			class="inputbox"
			component="com_store_locator"
			section="component" />
	</fieldset>
  <fieldset>
      <field
                name="usergroup"
                type="UserGroupList"
                label="Viewing Access:"
                description=" "
                layout="joomla.form.field.list-fancy-select"
                checksuperusergroup="0"
                default=""
                multiple="0"
                >
                <option value="0">Select User Group</option>
        </field> 
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="state" default="1" type="list" label=" " description=" " class="form-select-color-state" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="ordering"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_CREATED_BY"/>
    <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL" description="JGLOBAL_FIELD_MODIFIED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_MODIFIED_BY"/>
<field
		name="title"
		type="text"
		label="Location List Title"
    description=" "
		required="true"
	/>

	<field
		name="alias"
		type="text"
		label=" "
		description=" "
		hint="Alias is auto-generated from the title"
	/>
    <field name="paging" type="number" label=" " default="10" description=" "/>
    <field name="display" type="radio" label=" " default="0" class="btn-group">
            <option value="1">Table</option>
            <option value="2">Grid</option>
    </field>
    <field name="search_pos" type="radio" label="Search Position" default="0" class="btn-group">
            <option value="1">Top</option>
            <option value="2">Left</option>
            <option value="3">Right</option>
    </field>

    <field name="search_expanded" type="radio" label="Expanded" default="0" class="btn-group">
            <option value="1">Yes</option>
            <option value="2">No</option>
    </field>

   <field name="search_from" type="text" required="false" label="Search From Fields" description=""  />

    <field name="template_data" type="text" required="false" label="Location List Template" description=""  />

    <field name="arrange_by" type="text" required="false" label="Arrange By" description=""  />

    <field name="criteria" type="text" required="false" label="Location List criteria" description=""/>

    <field name="search_data" type="text" required="false" label="Location Search data" description=""/>

    <field
          name="frontend_access"
          type="radio"
          label="Frontend Access"
          default="0"
          >
          <option value="1">JYES</option>
          <option value="0">JNO</option>
      </field>

  </fieldset>
</form>
