<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Storelocator\Component\Store_locator\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="state" default="1" type="list" label=" " description=" " class="form-select-color-state" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    <field name="ordering"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_CREATED_BY"/>
    <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL" description="JGLOBAL_FIELD_MODIFIED_BY_DESC" hidden="true" hint="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_MODIFIED_BY"/>
    <field name="template_title" filter="safehtml" type="text" required="true" label="Template Title" description=" " hint="COM_STORE_LOCATOR_FORM_LBL_CARD_TEMP_TITLE"/>
    <field name="description" filter="JComponentHelper::filterText" type="textarea" required="false" label=" " description="how will this location card layout be used?" buttons="true" />
	<field name="open_position" filter="safehtml" type="radio" required="false" label=" " description="open position for the location card" class="btn-group">
      <option value="1">Map Overlay</option>
      <option value="2">Result Overlay</option>
    </field>
    <field name="close_position" type="radio" required="false" label=" " description="the X position to close the location card" class="btn-group">
      <option value="1">Top Left</option>
      <option value="2">Top Right</option>
      <option value="3">None</option>
    </field>
    <field name="template" filter="JComponentHelper::filterText" type="editor" required="false" label="COM_STORE_LOCATOR_FORM_LBL_LOCATORLOCATION_CARD_DATA" description=" " buttons="true"/>
  </fieldset>
</form>
