<?xml version="1.0" encoding="UTF-8"?>
<form addfieldprefix="Joomla\Component\Store_Locator\Administrator\Field">
	<fieldset name="general">
		<field
			name="id"
			type="number"
			label="JGLOBAL_FIELD_ID_LABEL"
			default="0"
			readonly="true"
			class="readonly"
		/>

		<field
			name="maptitle"
			type="text"
			label="COM_STORE_LOCATOR_FORM_LBL_MAPTITLE"
			required="true"
		/>

		  <field name="marker_icon" directory="" type="media" label="Marker Icon"/>
		  
		   <field name="defaultaddress" filter="safehtml" type="text" default="London, UK" label="Default Address"/> 
		  
		  <field name="defaultzoom" filter="safehtml" type="text" default="2" label="COM_STORE_LOCATOR_FORM_LBL_DEFAULTZOOM" description="COM_STORE_LOCATOR_FORM_DESC_DEFAULTZOOM" hint="COM_STORE_LOCATOR_FORM_LBL_DEFAULTZOOM"/>

        <field name="filter_radius" filter="safehtml" type="text" default="2" label="Filter Radius" hint="Seperated by commas(,)" description="Seperated by commas(,)"/>

        <field name="defaultradius" filter="safehtml" type="text" default="3" label="Default Radius"/>

        <field name="distance_unit" type="list" label="Distance Unit">
          <option value="1">Mile</option>
          <option value="2">Kilometer</option>
        </field>

















<!--  <field
          name="ip"
          type="radio"
          label="COM_STORE_LOCATOR_FORM_LBL_IP"
          default="0"
          >
				<option value="1">COM_STORE_LOCATOR_BY_IP</option>
				<option value="2">COM_STORE_LOCATOR_BY_ADDRESS</option>
		</field> -->

		<field
			name="ip"
			type="text"
			label="COM_STORE_LOCATOR_FORM_LBL_IP"
			required="false"
		/> 

		<field
			name="ip_address"
			type="text"
			label=""
			required="false"
			class="hide"
		/>


		 <field name="location_order" type="number" class="csthidn"/>
		 <field name="map_order" type="number" class="csthidn"/>

		 <field name="list_results" type="text" required="false" label="List Results By" description=""  />

		  <field
          name="showmaptitle"
          type="radio"
          label="Show Map Title"
          default="0"
          >
				<option value="1">JYES</option>
				<option value="0">JNO</option>
		</field>


		<field name="radius_search" type="list" label="COM_STORE_LOCATOR_FORM_LBL_RADIUS_SEARCH" description=" " hint="COM_STORE_LOCATOR_FORM_LBL_RADIUS_SEARCH">
  			<option value="">Default</option>
			<option value="1">1</option>
			<option value="5">5</option>
			<option value="10">10</option>
			<option value="20">20</option>
			<option value="30">30</option>
			<option value="40">40</option>
			<option value="50">50</option>
			<option value="60">60</option>
			<option value="70">70</option>
			<option value="80">80</option>
			<option value="90">90</option>
			<option value="100">100</option>
			<option value="110">110</option>
			<option value="120">120</option>
			<option value="130">130</option>
			<option value="140">140</option>
			<option value="150">150</option>
			<option value="160">160</option>
			<option value="170">170</option>
			<option value="180">180</option>
			<option value="190">190</option>
			<option value="200">200</option>
		</field>

    <field
			name="max_results"
			type="text"
			label="COM_STORE_LOCATOR_FORM_LBL_MAX"
		/>

		<field
			name="state"
			type="list"
			label="JSTATUS"
			class="form-select-color-state"
			default="1"
			validate="options"
			>
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="2">JARCHIVED</option>
			<option value="-2">JTRASHED</option>
		</field>

	</fieldset>

	<fieldset name="design">
		<field
			name="map_width"
			type="list"
			label="COM_STORE_LOCATOR_FORM_LBL_MAP_WIDTH"
		>
			<option value="">Default</option>
			<option value="1">1</option>
			<option value="2">2</option>
			<option value="3">3</option>
			<option value="4">4</option>
			<option value="5">5</option>
			<option value="6">6</option>
			<option value="7">7</option>
			<option value="8">8</option>
			<option value="9">9</option>
			<option value="10">10</option>
			<option value="11">11</option>
			<option value="12">12</option>
		</field>

		 <field name="map_height" type="number" label="Map Height(px)"/>

	  <field
			name="results_width"
			type="list"
			label="COM_STORE_LOCATOR_FORM_LBL_RESULTS_WIDTH"
		>
			<option value="">Default</option>
			<option value="1">1</option>
			<option value="2">2</option>
			<option value="3">3</option>
			<option value="4">4</option>
			<option value="5">5</option>
			<option value="6">6</option>
			<option value="7">7</option>
			<option value="8">8</option>
			<option value="9">9</option>
			<option value="10">10</option>
			<option value="11">11</option>
			<option value="12">12</option>
		</field>

	 <field name="map_theme" type="sql" default="10" label="Select map theme" query="SELECT id, theme_title FROM #__store_locator_map_themes" key_field="id" value_field="theme_title" />

	 <field name="map_skin" type="sql" default="10" label="Select map skin" query="SELECT id, skin_title FROM #__store_locator_map_skins" key_field="id" value_field="skin_title" />
  
	</fieldset>

	<fieldset name="filter">

		<field name="filter_position" filter="safehtml" type="radio" required="false" label="COM_STORE_LOCATOR_FORM_LBL_MAP_FILTER_POSITION" description=" " class="btn-group">
			<option value="1">Top</option>
			<option value="2">Left</option>
			<option value="3">Right</option>
			<option value="4">Bottom</option>
		</field>

		 <field name="filter" type="sql" default="10" label="Frontend Map Filter:" query="SELECT id, filter_title FROM #__store_locator_frontend_filter" key_field="id" value_field="filter_title" />
    

	</fieldset>

  <fieldset name="templates">

	<field name="location_result" type="sql" default="10" label="RESULT Template Layout:" query="SELECT id, template_title FROM #__store_locator_location_results" key_field="id" value_field="template_title" />

	<field name="location_card" type="sql" default="10" label="CARD Template Layout:" query="SELECT id, template_title FROM #__store_locator_card_template" key_field="id" value_field="template_title" />

	<field name="location_details" type="sql" default="10" label="DETAIL Template Layout:" query="SELECT id, template_title FROM #__store_locator_location_details" key_field="id" value_field="template_title" />

	</fieldset>

</form>
